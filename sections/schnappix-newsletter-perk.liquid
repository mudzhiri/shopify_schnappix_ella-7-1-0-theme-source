{% capture children %}
  <div class="sx-nl">
    <div class="sx-nl__inner">
      <div class="sx-nl__copy">
        <p class="sx-nl__kicker">{{ section.settings.kicker }}</p>
        <h2 class="sx-nl__heading">{{ section.settings.heading }}</h2>
        <div class="sx-nl__text rte">{{ section.settings.text }}</div>
        <ul class="sx-nl__bullets">
          {% if section.settings.bullet_1 != blank %}<li>{{ section.settings.bullet_1 }}</li>{% endif %}
          {% if section.settings.bullet_2 != blank %}<li>{{ section.settings.bullet_2 }}</li>{% endif %}
          {% if section.settings.bullet_3 != blank %}<li>{{ section.settings.bullet_3 }}</li>{% endif %}
        </ul>
      </div>

      <div class="sx-nl__form">
        {% form 'customer', class: 'sx-nl__form-inner' %}
          <input type="hidden" name="contact[tags]" value="newsletter, schnappix" />
          <label class="sx-nl__label" for="sx-nl-email-{{ section.id }}">{{ section.settings.input_label }}</label>
          <div class="sx-nl__row">
            <input
              id="sx-nl-email-{{ section.id }}"
              class="sx-nl__input"
              type="email"
              name="contact[email]"
              required
              autocomplete="email"
              placeholder="{{ section.settings.input_placeholder }}"
            >
            <button class="button button--primary sx-nl__btn" type="submit">
              {{ section.settings.button_label }}
            </button>
          </div>
          {% if form.posted_successfully? %}
            <p class="sx-nl__success">{{ section.settings.success_text }}</p>
          {% endif %}
          {% if form.errors %}
            <p class="sx-nl__error">{{ form.errors | default_errors }}</p>
          {% endif %}
        {% endform %}

        <div class="sx-nl__perk">
          <p class="sx-nl__perk-title">{{ section.settings.perk_title }}</p>
          <p class="sx-nl__perk-text">{{ section.settings.perk_text }}</p>
        </div>
      </div>
    </div>
  </div>

  <style>
    .sx-nl__inner{
      width: min(1170px, 100%);
      margin-inline: auto;
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: clamp(18px, 4vw, 56px);
      align-items: start;
    }
    @media (max-width: 989px){
      .sx-nl__inner{ grid-template-columns: 1fr; }
    }
    .sx-nl__kicker{
      margin: 0 0 10px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .14em;
      opacity: .85;
      font-size: .92rem;
    }
    .sx-nl__heading{
      margin: 0 0 14px;
      line-height: 1.05;
      text-transform: uppercase;
      font-size: clamp(28px, 3.3vw, 46px);
    }
    .sx-nl__text{ font-size: 1.1rem; }
    .sx-nl__bullets{
      margin: 18px 0 0;
      padding: 0 0 0 1.2em;
      display: grid;
      gap: 10px;
      font-weight: 700;
    }
    .sx-nl__form-inner{
      border: 2px solid rgba(0,0,0,.12);
      border-radius: 18px;
      background: rgba(255,255,255,.45);
      backdrop-filter: blur(6px);
      padding: 16px 16px;
    }
    .sx-nl__label{ display: block; font-weight: 900; text-transform: uppercase; letter-spacing: .10em; font-size: .85rem; margin-bottom: 10px; }
    .sx-nl__row{ display: grid; grid-template-columns: 1fr auto; gap: 10px; align-items: center; }
    @media (max-width: 520px){ .sx-nl__row{ grid-template-columns: 1fr; } }
    .sx-nl__input{
      width: 100%;
      border-radius: 16px;
      border: 2px solid rgba(0,0,0,.12);
      padding: 14px 14px;
      background: rgba(255,255,255,.60);
      font-weight: 650;
    }
    .sx-nl__btn{ white-space: nowrap; }
    .sx-nl__success{ margin: 14px 0 0; font-weight: 800; }
    .sx-nl__error{ margin: 14px 0 0; }
    .sx-nl__perk{
      margin-top: 14px;
      border-radius: 18px;
      border: 2px solid rgba(0,0,0,.12);
      background: rgba(255,255,255,.35);
      backdrop-filter: blur(6px);
      padding: 16px 16px;
    }
    .sx-nl__perk-title{ margin: 0; font-weight: 900; text-transform: uppercase; letter-spacing: .10em; font-size: .92rem; }
    .sx-nl__perk-text{ margin: 8px 0 0; font-weight: 650; opacity: .92; }
  </style>
{% endcapture %}

{% render 'section', section: section, children: children %}

{% schema %}
{
  "name": "Schnappix Newsletter Perk",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "custom.popup", "aside"] },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-10" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [
      { "value": "page-width", "label": "Page" },
      { "value": "full-width", "label": "Full" }
    ], "default": "page-width" },
    { "type": "range", "id": "padding-block-start", "min": 0, "max": 120, "step": 1, "unit": "px", "label": "Padding top", "default": 70 },
    { "type": "range", "id": "padding-block-end", "min": 0, "max": 120, "step": 1, "unit": "px", "label": "Padding bottom", "default": 70 },

    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Deals & Drops" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hol dir Angebote zuerst." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Neue Produkte, Restocks und Aktionen – direkt in dein Postfach. Kurz, selten, relevant.</p>" },
    { "type": "text", "id": "bullet_1", "label": "Bullet 1", "default": "Exklusive Drops aus Lagerbestand" },
    { "type": "text", "id": "bullet_2", "label": "Bullet 2", "default": "Aktionen & Bundle-Deals (Snacks + Drinks)" },
    { "type": "text", "id": "bullet_3", "label": "Bullet 3", "default": "Standort-News: Ludwigstrasse 14, Fürth" },

    { "type": "text", "id": "input_label", "label": "Input label", "default": "E-Mail" },
    { "type": "text", "id": "input_placeholder", "label": "Placeholder", "default": "deine@email.de" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Absenden" },
    { "type": "text", "id": "success_text", "label": "Success text", "default": "Danke! Bitte bestätige ggf. die E-Mail in deinem Postfach." },

    { "type": "text", "id": "perk_title", "label": "Perk title", "default": "Willkommens‑Vorteil" },
    { "type": "text", "id": "perk_text", "label": "Perk text", "default": "Erhalte als Erstes Infos zu neuen Produkten und zeitlich limitierten Deals." }
  ],
  "presets": [
    { "name": "Schnappix Newsletter Perk", "category": "Forms" }
  ]
}
{% endschema %}

