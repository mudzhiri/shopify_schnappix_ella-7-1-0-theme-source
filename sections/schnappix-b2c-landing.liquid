{% capture children %}
  <div class="schnappix-b2c">
    <div class="schnappix-b2c__grid">
      <div class="schnappix-b2c__copy">
        {% if section.settings.kicker != blank %}
          <p class="schnappix-b2c__kicker">{{ section.settings.kicker }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="schnappix-b2c__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="schnappix-b2c__subheading rte">{{ section.settings.subheading }}</div>
        {% endif %}

        {% if section.settings.usp_1 != blank or section.settings.usp_2 != blank or section.settings.usp_3 != blank %}
          <ul class="schnappix-b2c__usp">
            {% if section.settings.usp_1 != blank %}<li>{{ section.settings.usp_1 }}</li>{% endif %}
            {% if section.settings.usp_2 != blank %}<li>{{ section.settings.usp_2 }}</li>{% endif %}
            {% if section.settings.usp_3 != blank %}<li>{{ section.settings.usp_3 }}</li>{% endif %}
          </ul>
        {% endif %}

        <div class="schnappix-b2c__cta">
          {% if section.settings.primary_cta_label != blank %}
            <a class="button button--primary" href="{{ section.settings.primary_cta_link }}">{{ section.settings.primary_cta_label }}</a>
          {% endif %}
          {% if section.settings.secondary_cta_label != blank %}
            <a class="button button--secondary" href="{{ section.settings.secondary_cta_link }}">{{ section.settings.secondary_cta_label }}</a>
          {% endif %}
        </div>

        <div class="schnappix-b2c__meta">
          <div class="schnappix-b2c__meta-card">
            <p class="schnappix-b2c__meta-title">Standort</p>
            <p class="schnappix-b2c__meta-text">
              {{ section.settings.address_line_1 }}<br>
              {{ section.settings.address_line_2 }}
            </p>
            {% if section.settings.maps_link != blank %}
              <a class="schnappix-b2c__meta-link" href="{{ section.settings.maps_link }}" target="_blank" rel="noopener noreferrer">Auf Google Maps öffnen</a>
            {% endif %}
          </div>

          <div class="schnappix-b2c__meta-card">
            <p class="schnappix-b2c__meta-title">Für Endkunden (B2C)</p>
            <p class="schnappix-b2c__meta-text">
              Alles was im Automaten läuft – jetzt auch im Online‑Shop. Schnell bestellt, bequem geliefert.
            </p>
          </div>
        </div>
      </div>

      <div class="schnappix-b2c__media">
        {% assign hero_img = section.settings.hero_image %}
        {% if hero_img != blank %}
          <div class="schnappix-b2c__heroimg">
            {{ hero_img | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 520px, 90vw', widths: '480,640,800,1000,1200', alt: section.settings.hero_image_alt | escape }}
          </div>
        {% elsif section.settings.hero_image_url != blank %}
          <div class="schnappix-b2c__heroimg">
            <img src="{{ section.settings.hero_image_url }}" alt="{{ section.settings.hero_image_alt | escape }}" loading="lazy">
          </div>
        {% endif %}

        <div class="schnappix-b2c__tiles">
          {% for i in (1..3) %}
            {% capture tile_img_key %}tile_image_{{ i }}{% endcapture %}
            {% capture tile_alt_key %}tile_image_alt_{{ i }}{% endcapture %}
            {% capture tile_url_key %}tile_image_url_{{ i }}{% endcapture %}
            {% assign tile_img = section.settings[tile_img_key] %}
            {% assign tile_alt = section.settings[tile_alt_key] %}
            {% assign tile_url = section.settings[tile_url_key] %}

            {% if tile_img != blank or tile_url != blank %}
              <div class="schnappix-b2c__tile">
                {% if tile_img != blank %}
                  {{ tile_img | image_url: width: 700 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 160px, 40vw', widths: '220,320,480,640,700', alt: tile_alt | escape }}
                {% else %}
                  <img src="{{ tile_url }}" alt="{{ tile_alt | escape }}" loading="lazy">
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <style>
    .schnappix-b2c { width: 100%; }
    .schnappix-b2c__grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: clamp(20px, 4vw, 56px);
      align-items: start;
      width: min(1170px, 100%);
      margin-inline: auto;
    }
    @media (max-width: 989px) {
      .schnappix-b2c__grid { grid-template-columns: 1fr; }
    }

    .schnappix-b2c__kicker {
      letter-spacing: .14em;
      text-transform: uppercase;
      font-weight: 700;
      opacity: .8;
      margin: 0 0 12px;
    }
    .schnappix-b2c__heading {
      margin: 0 0 14px;
      line-height: 1.02;
      font-size: clamp(34px, 4.2vw, 64px);
      text-transform: uppercase;
    }
    .schnappix-b2c__subheading { font-size: 1.15rem; opacity: .95; }
    .schnappix-b2c__usp {
      margin: 22px 0 0;
      padding: 0 0 0 1.2em;
      display: grid;
      gap: 10px;
      font-weight: 600;
    }
    .schnappix-b2c__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }

    .schnappix-b2c__meta {
      margin-top: 28px;
      display: grid;
      gap: 14px;
    }
    .schnappix-b2c__meta-card {
      border: 2px solid rgba(0,0,0,.12);
      border-radius: 16px;
      padding: 16px 16px;
      backdrop-filter: blur(6px);
      background: rgba(255,255,255,.4);
    }
    .color-scheme-9 .schnappix-b2c__meta-card,
    .color-scheme-10 .schnappix-b2c__meta-card,
    .color-scheme-11 .schnappix-b2c__meta-card {
      background: rgba(255,255,255,.22);
    }
    .schnappix-b2c__meta-title { margin: 0 0 6px; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; font-size: .92rem; }
    .schnappix-b2c__meta-text { margin: 0; opacity: .95; }
    .schnappix-b2c__meta-link { display: inline-block; margin-top: 10px; text-decoration: underline; font-weight: 700; }

    .schnappix-b2c__media { position: sticky; top: 16px; }
    @media (max-width: 989px) { .schnappix-b2c__media { position: static; } }

    .schnappix-b2c__heroimg img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 18px;
      border: 2px solid rgba(0,0,0,.12);
      background: rgba(255,255,255,.35);
    }
    .schnappix-b2c__tiles {
      margin-top: 14px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .schnappix-b2c__tile img {
      width: 100%;
      height: 120px;
      object-fit: contain;
      display: block;
      border-radius: 14px;
      border: 2px solid rgba(0,0,0,.12);
      background: rgba(255,255,255,.55);
      padding: 10px;
    }
  </style>
{% endcapture %}

{% render 'section', section: section, children: children %}

{% schema %}
{
  "name": "Schnappix B2C Landing",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "custom.popup", "aside"]
  },
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-10" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [
      { "value": "page-width", "label": "Page" },
      { "value": "full-width", "label": "Full" }
    ], "default": "page-width" },
    { "type": "range", "id": "padding-block-start", "min": 0, "max": 120, "step": 1, "unit": "px", "label": "Padding top", "default": 60 },
    { "type": "range", "id": "padding-block-end", "min": 0, "max": 120, "step": 1, "unit": "px", "label": "Padding bottom", "default": 60 },

    { "type": "text", "id": "kicker", "label": "Kicker", "default": "24/7 Kiosk Fürth" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SCHNAPPIX – Dein 24/7 Shop" },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>Wir verkaufen die Produkte aus unserem Lager direkt an Endkunden – schnell, unkompliziert und 24/7 inspiriert vom Automaten in Fürth.</p>" },

    { "type": "text", "id": "usp_1", "label": "USP 1", "default": "Schnell bestellen – unkompliziert geliefert" },
    { "type": "text", "id": "usp_2", "label": "USP 2", "default": "Beliebte Snacks & Getränke wie im Automaten" },
    { "type": "text", "id": "usp_3", "label": "USP 3", "default": "Standort: Ludwigstrasse 14, 90763 Fürth" },

    { "type": "text", "id": "primary_cta_label", "label": "Primary CTA label", "default": "Zum Sortiment" },
    { "type": "url", "id": "primary_cta_link", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label", "default": "Standort ansehen" },
    { "type": "url", "id": "secondary_cta_link", "label": "Secondary CTA link" },

    { "type": "text", "id": "address_line_1", "label": "Address line 1", "default": "Ludwigstrasse 14" },
    { "type": "text", "id": "address_line_2", "label": "Address line 2", "default": "90763 Fürth" },
    { "type": "url", "id": "maps_link", "label": "Google Maps link", "default": "https://maps.google.com/?q=Ludwigstrasse+14,+90763+Fürth" },

    { "type": "header", "content": "Hero image" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (uploaded)" },
    { "type": "url", "id": "hero_image_url", "label": "Hero image URL (optional)" },
    { "type": "text", "id": "hero_image_alt", "label": "Hero image alt", "default": "Schnappix Produkte" },

    { "type": "header", "content": "Tiles (3 small images)" },
    { "type": "image_picker", "id": "tile_image_1", "label": "Tile image 1 (uploaded)" },
    { "type": "url", "id": "tile_image_url_1", "label": "Tile image 1 URL" },
    { "type": "text", "id": "tile_image_alt_1", "label": "Tile alt 1", "default": "Getränke" },

    { "type": "image_picker", "id": "tile_image_2", "label": "Tile image 2 (uploaded)" },
    { "type": "url", "id": "tile_image_url_2", "label": "Tile image 2 URL" },
    { "type": "text", "id": "tile_image_alt_2", "label": "Tile alt 2", "default": "Snacks" },

    { "type": "image_picker", "id": "tile_image_3", "label": "Tile image 3 (uploaded)" },
    { "type": "url", "id": "tile_image_url_3", "label": "Tile image 3 URL" },
    { "type": "text", "id": "tile_image_alt_3", "label": "Tile alt 3", "default": "Energy" }
  ],
  "presets": [
    { "name": "Schnappix B2C Landing", "category": "Storytelling" }
  ]
}
{% endschema %}

