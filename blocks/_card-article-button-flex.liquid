      "id": "padding-inline-start",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "label": "t:settings.left"
    }
  ],
  "presets": [
    {
      "name": "t:names.article_button",
      "settings": {
        "article": "{{ closest.article }}"
      }
    }
  ]
}
{% endschema %}
