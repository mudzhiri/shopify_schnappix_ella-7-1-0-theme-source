{% render 'search-block', block: block %}

{% schema %}
{
  "name": "Search",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "default": "Search entire store here"
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Placeholder color",
      "default": "#202020"
    },
    {
      "type": "select",
      "id": "result_type",
      "label": "Search in",
      "options": [
        { "value": "all", "label": "Entire store" },
        { "value": "product", "label": "Products" },
        { "value": "article", "label": "Articles" },
        { "value": "page", "label": "Pages" }
      ],
      "default": "all"
    },
    {
      "type": "header",
      "content": "Bar style"
    },
    {
      "type": "color",
      "id": "bar_background",
      "label": "Bar background",
      "default": "#b8ff00"
    },
    {
      "type": "color",
      "id": "bar_text_color",
      "label": "Bar text color",
      "default": "#202020"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#202020"
    },
    {
      "type": "color",
      "id": "icon_circle_color",
      "label": "Icon circle color",
      "default": "#202020"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Bar max width",
      "min": 320,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 880
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Bar height",
      "min": 44,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Search",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}

