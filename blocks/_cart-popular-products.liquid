{% render 'cart-popular-products', block: block %}

{% schema %}
{
  "name": "Cart popular products",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "popular_products_title",
      "label": "t:settings.title",
      "default": "You May Also Like"
    },
    {
      "type": "collection",
      "id": "popular_products_collection",
      "label": "t:settings.collection"
    },
    {
      "type": "range",
      "id": "popular_products_show",
      "label": "Show products",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "visible_if": "{{ block.settings.popular_products_collection != blank }}"
    },
    {
      "type": "checkbox",
      "id": "popular_products_arrows",
      "label": "Show arrows",
      "default": true,
      "visible_if": "{{ block.settings.popular_products_collection != blank }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Cart popular products"
    }
  ]
}
{% endschema %}
